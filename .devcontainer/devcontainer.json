{
	"name": "project",
	"image": "mcr.microsoft.com/devcontainers/python:3",
	"features": {
		"ghcr.io/devcontainers-extra/features/mise:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"hverlin.mise-vscode",
				"tamasfe.even-better-toml",
				"redhat.vscode-yaml",
				"charliermarsh.ruff",
				"ms-python.python"
			]
		}
	},
	"postCreateCommand": "echo 'eval \"$(mise activate bash)\"' >> ~/.bashrc",
	"forwardPorts": [
		"8000:8000"
	]
}
